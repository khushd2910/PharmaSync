# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/pharma_management

# JWT - access token (short-lived, used for normal API auth)
JWT_SECRET=change_this_to_a_long_random_secret
ACCESS_TOKEN_EXPIRES_IN=15m

# JWT - refresh token (long-lived, used only to silently renew access tokens)
# MUST be a different secret than JWT_SECRET
REFRESH_TOKEN_SECRET=change_this_to_a_different_long_random_secret
REFRESH_TOKEN_EXPIRES_IN=30d

# Client URL(s) for CORS — comma-separate multiple origins if needed
CLIENT_URL=http://localhost:5173

# If true, users must click the emailed verification link before they can log in.
# Keep false for easy local testing without a real mail provider.
REQUIRE_EMAIL_VERIFICATION=false

# SMTP (optional but recommended for real password-reset emails).
# EASIEST OPTION — Gmail: set SMTP_SERVICE=gmail, SMTP_USER=you@gmail.com,
# and SMTP_PASS=an App Password (not your normal password — create one at
# https://myaccount.google.com/apppasswords, requires 2FA enabled on the account).
SMTP_SERVICE=
SMTP_USER=
SMTP_PASS=

# ALTERNATIVE — any other provider (SendGrid, Mailgun, company SMTP, etc.)
# Leave SMTP_SERVICE blank and fill these in instead:
SMTP_HOST=
SMTP_PORT=587

EMAIL_FROM=no-reply@pharma-management.local

# If none of the above are set, emails are sent through a free Ethereal
# test inbox instead — the server console will print a preview link so you
# can still see the email and test the flow, but it won't reach a real inbox.
