# Copy this file to python-service/.env and fill in the same MongoDB URI
# your Node server uses (server/.env's MONGO_URI) — the analysis job reads
# and writes to that same database.
MONGO_URI=mongodb://localhost:27017/pharmasync

# Optional overrides — defaults shown. Keep LOW_STOCK_THRESHOLD in sync with
# server/utils/inventoryConstants.js if you change it.
LOW_STOCK_THRESHOLD=10
SALES_LOOKBACK_DAYS=30
FAST_SLOW_TOP_N=10
